│   │       └── script_manager.py      # Load question scripts
│   ├── pipeline/
│   │   ├── bot.py                     # Pipecat pipeline definition
│   │   └── session_processor.py       # Custom processor (LangChain bridge)
│   ├── scripts/                       # JSON question scripts
│   ├── requirements.txt
│   └── .env
├── frontend/                          # Session page + Doctor view
└── docker-compose.yml
```

